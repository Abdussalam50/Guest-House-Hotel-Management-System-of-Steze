        }
    })
};

$.fn.isChecked = function () {
    var checked = $(this).attr('checked');
    if ($(this).is(":checked")) {
        return true;
    } else if ($(this).prop('checked')) {
        return true;
    } else {
        return false;
    }
};

$.fn.datetimePickerConvert = function (options) {
